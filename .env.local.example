# ── Supabase ─────────────────────────────────────────────────────────────
# Project Settings → API in your Supabase dashboard.

# Public — safe to expose to the browser (RLS protects the data).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server only — NEVER expose this. Used to verify worker PINs and seed data.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret used to sign the worker session cookie (any long random string).
WORKER_SESSION_SECRET=change-me-to-a-long-random-string

# ── LINE notifications (Phase 4) ─────────────────────────────────────────
# Secret that protects the /api/cron/* endpoints. Vercel Cron automatically
# sends this as "Authorization: Bearer <CRON_SECRET>". Any long random string.
CRON_SECRET=change-me-to-another-long-random-string
# The LINE Channel Access Token + recipient are configured in-app under
# Admin → ตั้งค่า LINE (stored in the database, not here).
